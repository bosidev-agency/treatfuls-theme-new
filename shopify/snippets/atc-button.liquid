<atc-button
  class="product_content-buttons"
  {% if cart_notification %}
    data-cart-notification="{{ cart_notification }}"
  {% endif %}
>
  {%- form 'product',
    product,
    class: '',
    data-product-form: '',
    data-product-handle: product.handle,
    data-enable-history-state: 'true',
    data-productid: product.id
  -%}
    {% if product.metafields.custom.product_content != blank %}
      {% capture product_content %}
      [
        {% for content in product.metafields.custom.product_content.value.content.value %}
          {
            "id": "{{ content.product }}",
            "quantity": {{ content.quantity }}
          }{% if forloop.last == false %},{% endif %}
        {% endfor %}
      ]
    {% endcapture %}

      <script type="application/json">
        {{ product_content  }}
      </script>

      <input
        type="hidden"
        name="properties[_bundleData]"
        value="{{ product_content | escape }}"
      >

      {% assign has_preorder = false %}
      {% assign pre_order_product = null %}
      {% assign is_out_of_stock = false %}

      {% for content in product.metafields.custom.product_content.value.content.value %}
        {% assign content_product = content.product.value %}

        {% if content_product.product.metafields.custom.preorder_date != blank %}
          {% assign has_preorder = true %}
          {% assign pre_order_product = content_product.product.value.product %}
        {% endif %}
        {% if content_product.available == false or content_product.quantity < content_product.inventory_quantity %}
          {% assign is_out_of_stock = true %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% if product.metafields.custom.product_content != blank %}
      {% if is_out_of_stock == false and has_preorder %}
        <span class="product-info__shipping">
          {{ 'products.pre_order.shipping_info' | t: date: pre_order_product.metafields.custom.preorder_date }}
        </span>

        <input
          type="hidden"
          id="PreorderNote"
          name="properties[{{ 'products.pre_order.note' | t }}]"
          value="{{ 'products.pre_order.pre_order' | t }}"
          data-product-property
        >
        <input
          type="hidden"
          id="PreorderShipping"
          name="properties[{{ 'products.pre_order.shipping' | t }}]"
          value="{{ pre_order_product.metafields.custom.preorder_date }}"
          data-product-property
        >
      {% endif %}
    {% else %}
      {%- if current_variant.available == true and product.metafields.custom.preorder_date != blank -%}
        <span class="product-info__shipping">
          {{ 'products.pre_order.shipping_info' | t: date: product.metafields.custom.preorder_date }}
        </span>

        <input
          type="hidden"
          id="PreorderNote"
          name="properties[{{ 'products.pre_order.note' | t }}]"
          value="{{ 'products.pre_order.pre_order' | t }}"
          data-product-property
        >
        <input
          type="hidden"
          id="PreorderShipping"
          name="properties[{{ 'products.pre_order.shipping' | t }}]"
          value="{{ product.metafields.custom.preorder_date }}"
          data-product-property
        >
      {%- endif -%}
    {% endif %}

    <label class="quantity-element__label">
      <input
        class="quantity-element__input"
        type="hidden"
        id="Quantity"
        name="quantity"
        value="1"
        min="1"
        max="99"
        maxlength="2"
        data-quantity="input"
      >
    </label>

    {% unless product.has_only_default_variant %}
      <a
        class="button product-form__button"
        href="{{ product.url }}"
      >
        <span
          class="product-form__button-text product-form__button-text--add-to-card"
        >
          {% if product.gift_card? %}
            {{ 'collections.product_card.view_gift_card' | t }}
          {% else %}
            {{ 'collections.product_card.view_product' | t }}
          {% endif %}
        </span>
      </a>
    {% else %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <div class="product-form__wrapper">
        <div class="error-message hidden"></div>
        <button
          class="button product-form__button"
          type="submit"
          name="add"
          {% unless product.available == true %}
            disabled
          {% endunless %}
          data-submit-button
        >
          <span
            class="product-form__button-text product-form__button-text--add-to-card"
            data-submit-button-text
          >
            {% if product.metafields.custom.product_content != blank %}
              {%- if is_out_of_stock == false and product.variants.first.available -%}
                <span class="product-form__button-price" style="margin-right:5px;">{{ product.price | money }}</span>
                {% if has_preorder %}
                  {{- 'collections.product_card.preorder' | t -}}
                {% else %}
                  {{- 'collections.product_card.add_to_cart' | t -}}
                {% endif %}
              {%- else -%}
                {{ 'collections.product_card.sold_out' | t }}
              {%- endif -%}
            {% else %}
              {%- if product.variants.first.available == true -%}
                <span class="product-form__button-price" style="margin-right:5px;">{{ product.price | money }}</span>
                {% if product.metafields.custom.preorder_date != blank %}
                  {{- 'collections.product_card.preorder' | t -}}
                {% else %}
                  {{- 'collections.product_card.add_to_cart' | t -}}
                {% endif %}
              {%- else -%}
                {{ 'collections.product_card.sold_out' | t }}
              {%- endif -%}
            {% endif %}
          </span>
        </button>
      </div>
    {% endunless %}
  {%- endform -%}
</atc-button>
