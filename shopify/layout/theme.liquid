<!-- FV_1779435374_FV_{{shop.metafields.fudge.rid.value}} -->
<!doctype html> 
<html class="no-js" lang="{{- shop.locale -}}">
	<head>
{% render 'fudge-head-start' %}
{% render "load-metafields" %}

		<meta charset="utf-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
		<meta name="viewport" content="width=device-width,initial-scale=1">
		<meta name="theme-color" content="{{- settings.color_button -}}">
    {% if product.metafields.custom.hide_product %}
      <meta name="robots" content="noindex">
    {% endif %}
      	<!-- Google Tag Manager -->
        <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-NFCVWZ5');</script>
        <!-- End Google Tag Manager -->
		<link rel="canonical" href="{{- canonical_url -}}">

{% render 'ultimate-datalayer' %}

      
		{%- if settings.favicon != blank -%}
			<link rel="shortcut icon" href="{{ settings.favicon | img_url: '32x32' }}" type="image/png">
		{%- endif -%}

		{%- capture seo_title -%}
			{%- if template == 'search' and search.performed == true -%}
				{{ 'general.search.heading' | t: count: search.results_count }}: {{ 'general.search.results_with_count' | t: terms: search.terms, count: search.results_count }}
			{%- else -%}
				{{ page_title }}
			{%- endif -%}

			{%- if current_tags -%}
				{%- assign meta_tags = current_tags | join: ', ' -%} &ndash; {{ 'general.meta.tags' | t: tags: meta_tags -}}
			{%- endif -%}

			{%- if current_page != 1 -%}
				&ndash; {{ 'general.meta.page' | t: page: current_page }}
			{%- endif -%}

			{%- assign escaped_page_title = page_title | escape -%}
			{%- unless escaped_page_title contains shop.name -%}
				&ndash; {{ shop.name }}
			{%- endunless -%}
		{%- endcapture -%}

		<title>
			{{- seo_title | strip -}}
		</title>

		{%- if page_description -%}
			<meta name="description" content="{{- page_description | escape -}}">
		{%- endif -%}

		{%- render 'social-meta-tags' -%}
		{%- render 'head-theme-meta' with layout: 'theme' -%}

		{%- render 'custom-variables.css' -%}
    {%- render 'css-variables' -%}

		{% render 'social-meta-tags' %}

    {{ 'FoundersGrotesk-Regular.woff2' | asset_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {{ 'FoundersGrotesk-Bold.woff2' | asset_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {{ 'FoundersGroteskMono-Medium.woff2' | asset_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% render 'fonts' %}

    {{ 'bundle.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'custom.static.css' | asset_url | stylesheet_tag: preload: true }}

		{%- if template.directory == 'customers' -%}
			<script src="{{ 'shopify_common.js' | shopify_asset_url }}" defer="defer"></script>
		{%- endif -%}
    <script src="{{- 'bundle.js' | asset_url -}}" defer="defer"></script>
    <script src="{{- 'custom.static.js' | asset_url -}}" defer="defer"></script>
      
     



{{ content_for_header }}

		<script>
			const LOCATION_PATHNAME = window.location.pathname;
			if ( LOCATION_PATHNAME === '/collections' || LOCATION_PATHNAME === '/collections/') {
				location.href = "{{ shop.url }}/collections/all";
			}
		</script>
     {% render 'judgeme_core' %}
     {% render 'translations' %}
	</head>

	{%- assign body_classes = "template " -%}
	{%- capture template_class -%}
		{%- if request.path contains 'challenge' -%}template-challenge {%- else -%}template-{{ template.name | handle }} {%- endif -%}
		{% if template.suffix != blank %}template-{{ template.name | handle }}--{{ template.suffix | handle }}{% endif %}
	{%- endcapture -%}

	{%- assign body_classes = body_classes | append: template_class -%}
  {%- assign resource = '' -%}

  {% if template.name == 'product' %}
    {% assign resource = product %}
  {% elsif template.name == 'collection' %}
    {% assign resource = collection %}
  {% elsif template.name == 'page' %}
    {% assign resource = page %}
  {% elsif template.name == 'article' %}
    {% assign resource = article %}
  {% endif %}

  {%- render 'color-scheme', resource: resource -%}

		<body class="{{ body_classes }}">
	      	<!-- Google Tag Manager (noscript) -->
	        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NFCVWZ5"
	        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
	        <!-- End Google Tag Manager (noscript) -->
	    {% sections 'header-group' %}

			{{ content_for_layout }}

			{%- section 'footer' -%}

			{%- section 'main-cart-mini' -%}
	    {%- render 'cart-notification' -%}
	    
	    {%- if template.name == 'collection' -%}
	    <style>
		      /* Header in lila #ceb0d1 färben */
		      .header {
		        background-color: #ceb0d1 !important;
		      }
		      /* Header Navigation Links weiß */
		      .header-nav__link,
		      .header-nav__menu a {
		        color: #ffffff !important;
		      }
		      /* Icons weiß erzwingen */
		      .header-nav__link svg,
		      .header-nav__link svg path,
		      .header-nav__link svg circle,
		      .header-nav__link svg line {
		        stroke: #ffffff !important;
		        fill: none !important;
		      }
		      .header-nav__link svg circle[fill],
		      .header-nav__link svg circle[r="1"] {
		        fill: #ffffff !important;
		        stroke: none !important;
		      }
		      /* Hamburger Menü Striche weiß */
		      .hamburger-inner,
		      .hamburger-inner::before,
		      .hamburger-inner::after {
		        background-color: #ffffff !important;
		      }
		      /* Pill-Texte in featured-collections weiß */
		      .collection-swiper__link span,
		      .title-bg {
		        color: #ffffff !important;
		      }
		      /* Featured Collections Section in lila #ceb0d1 */
		      .featured-collections {
		        background-color: #ceb0d1 !important;
		      }
		      /* Triangular Zacken in lila #ceb0d1 für alle Collection-Seiten AUSSER alle-produkte */
		      .template:not(.template-collection--alle-produkte) .base-triangular-line {
		        color: #ceb0d1 !important;
		      }
		      /* Zacken lila für alle-produkte Collection Template */
		      .template-collection--alle-produkte .base-triangular-line,
		      .template-collection--alle-produkte .base-triangular-line svg,
		      .template-collection--alle-produkte .base-triangular-line svg path {
		        color: #ceb0d1 !important;
		        fill: #ceb0d1 !important;
		      }
	      /* Collection Section (Produkt-Grid) weiß */
	      .collection-template,
	      .products_listing {
	        background-color: #FFFFFF !important;
	      }
	      /* Produktnamen schwarz */
	      .product-card__title,
	      .grid-view-item__title {
	        color: #2d2d2d !important;
	      }
	      /* Product Hover Accent in Nude - CSS Variablen */
	      .products_listing,
	      .collection-template,
	      #shopify-section-f507b3a2-8d74-41d4-a1c9-d3dc0f20e0ee {
	        --product-card-hover-color: #F5F0EB !important;
	        --section-accent-color: #F5F0EB !important;
	      }
	      /* Product Hover Accent in Nude - Fallback */
	      .product-card:hover,
	      .grid-view-item:hover,
	      .product-card--hover,
	      .product-card__link:hover {
	        background-color: #F5F0EB !important;
	      }
	      /* CTA Button (Preis/Warenkorb) in Lila #C081A9 via CSS-Variable */
	      .products_listing {
	        --section-accent-color: #C081A9 !important;
	      }
	      /* CTA Button (Preis/Warenkorb) in Lila #C081A9 - Fallback */
	      .products_listing .product_content-buttons .product-form__button,
	      .products_listing atc-button .button,
	      .products_listing .product_content-buttons button,
	      .products_listing .product-form__button[type="submit"] {
	        background-color: #C081A9 !important;
	        border-color: #C081A9 !important;
	        color: #FFFFFF !important;
	      }
	      .products_listing .product-form__button-price {
	        color: #FFFFFF !important;
	      }
	      /* Labels (Vegan, Bio, etc.) in Nude #F5F0EB */
	      .products_listing__label {
	        background-color: #F5F0EB !important;
	      }
	      /* Lila Schatten vom Slider-Button entfernen */
	      .featured-collections .swiper-button-next {
	        background: rgba(255,255,255,0.9) !important;
	        box-shadow: none !important;
	      }
	      .featured-collections .swiper-button-prev {
	        background: rgba(255,255,255,0.9) !important;
	        box-shadow: none !important;
	      }
		    </style>
		    {%- endif -%}

		    {%- assign nav_collection_ids = '283713765570,564020248840,519402258696,537731006728,519351828744' -%}
		    {%- if nav_collection_ids contains collection.id %}
		    <style>
		      /* Featured Collections Titel-Überschriften weiß - höchste Priorität */
		      #shopify-section-template--29080884609288__product-grid .title-bg,
		      #shopify-section-template--29080884609288__product-grid .home-products__title,
		      #shopify-section-template--29080884609288__product-grid h2.title-bg {
		        color: #ffffff !important;
		      }
		    </style>
		    {%- endif -%}

		{%- if template.directory == 'customers' -%}
			<script src="{{- 'shopify_common.js' | shopify_asset_url -}}" defer></script>
		{%- endif -%}
    {%- section 'global-newsletter-popup' -%}
	  {%- section 'klaviyo-popups' -%}
        {% include "bc_banner" %}
</body>
</html>

{%- if product.metafields.custom.redirect != blank -%}
  <script>
    window.location = '{{ product.metafields.custom.redirect }}';
  </script>
{%- endif -%}


<style>
  @media screen and (min-width: 800px) {

  .jdgm-carousel-wrapper .jdgm-carousel-item {

    width: 48.5% !important;
}
}

  @media screen and (max-width: 600px) {

  .jdgm-carousel-wrapper .jdgm-carousel-item {

    width: 95% !important;
}
}

</style>

