{% comment %} TODO: Rename this section {% endcomment %}
{%- assign nav_collection_ids = '283713765570,564020248840,519402258696,537731006728,519351828744' -%}
<section
  class="featured-collections{% if nav_collection_ids contains collection.id %} triangular-balance{% endif %}"
  data-section-id="{{- section.id -}}"
  data-section-type="featured-collections"
>
  <div class="featured-collections__container page-width">
    {%- if section.settings.heading_desktop != blank -%}
      <h2
        class="title-bg home-products__title hidden-phone"
      >
        {{ section.settings.heading_desktop }}
      </h2>
    {%- endif -%}

    {%- if section.settings.heading_mobile != blank -%}
      <h2
        class="title-bg home-products__title hidden-desktop"
      >
        {{ section.settings.heading_mobile }}
      </h2>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="swiper-container-wrapper">
        <collection-slider class="swiper" data-slides="{{ section.blocks.size }}">
          <div class="swiper-wrapper">
            {%- for block in section.blocks -%}
              {% case block.type %}
                {% when 'collection_item' %}
                  {%- assign block_collection = collections[block.settings.collection] -%}
                  {%- assign collection_image = block.settings.image -%}
                  {%- assign collection_title = block_collection.title -%}

                  {%- if block.settings.collection_title != blank -%}
                    {%- assign collection_title = block.settings.collection_title -%}
                  {%- endif -%}

                  <div class="custom_slider swiper-slide">
                    {%- if block_collection != blank -%}
                      <a
                        href="{{- block_collection.url -}}"
                        class="{% if collection == block_collection %}active{% endif %}"
                      >
                        {%- if collection_image != blank -%}
                          {{
                            collection_image
                            | image_url: width: 800
                            | image_tag: class: 'hidden-phone', alt: collection_image.alt
                          }}
                        {%- else -%}
                          {{
                            block_collection.featured_image
                            | image_url: width: 800
                            | image_tag: class: 'hidden-phone', alt: block_collection.featured_image.alt
                          }}
                        {%- endif -%}
                        <div class="collection-swiper__link">
                          <span>{{- collection_title -}}</span>
                        </div>
                      </a>
                    {%- else -%}
                      {{ 'collection-1' | placeholder_svg_tag }}
                    {%- endif -%}
                  </div>
                {% when 'product_item' %}
                  {%- assign block_product = block.settings.product-%}
                  {%- assign product_image = block_product.featured_image -%}
                  {%- assign product_title = block_product.title -%}

                  <div class="custom_slider swiper-slide">
                    {%- if block_product != blank -%}
                      <a
                        href="{{- block_product.url -}}"
                      >
                        {%- if product_image != blank -%}
                          {{
                            product_image
                            | image_url: width: 800
                            | image_tag: class: 'hidden-phone', alt: product_image.alt
                          }}
                        {%- else -%}
                          {{
                            block_product.featured_image
                            | image_url: width: 800
                            | image_tag: class: 'hidden-phone', alt: block_product.featured_image.alt
                          }}
                        {%- endif -%}
                        <div class="collection-swiper__link">
                          <span>{{- product_title -}}</span>
                        </div>
                      </a>
                    {%- else -%}
                      {{ 'collection-1' | placeholder_svg_tag }}
                    {%- endif -%}
                  </div>
              {% endcase %}
            {% endfor %}
          </div>
        </collection-slider>
        <div class="swiper-button-prev">
        </div>
        <div class="swiper-button-next">
        </div>
      </div>
    {%- endif -%}
  </div>
  <div class="base-triangular-line">
    {%- render 'icon-triangular-line' -%}
  </div>
</section>

<script>
(function() {
  // Slider-Position beim Klicken auf einen Collection-Link speichern
  const slider = document.querySelector('#shopify-section-{{ section.id }} collection-slider');
  if (slider) {
    const links = slider.querySelectorAll('a[href*="/collections/"]');
    links.forEach(link => {
      link.addEventListener('click', function(e) {
        const slide = this.closest('.swiper-slide');
        const slides = Array.from(slider.querySelectorAll('.swiper-slide'));
        const index = slides.indexOf(slide);
        if (index >= 0) {
          sessionStorage.setItem('collectionSliderIndex', index);
        }
      });
    });

    // Gespeicherte Position beim Laden wiederherstellen
    const savedIndex = sessionStorage.getItem('collectionSliderIndex');
    if (savedIndex !== null) {
      // Mehrere Versuche, falls Swiper noch nicht initialisiert
      const tryRestore = (attempts = 0) => {
        const swiperInstance = slider.swiper;
        if (swiperInstance) {
          swiperInstance.slideTo(parseInt(savedIndex, 10), 0);
          sessionStorage.removeItem('collectionSliderIndex');
        } else if (attempts < 20) {
          setTimeout(() => tryRestore(attempts + 1), 100);
        }
      };
      tryRestore();
    }
  }
})();
</script>

