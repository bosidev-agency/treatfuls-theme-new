<style>
  #shopify-section-{{ section.id }} {
    {%- if section.settings.background_color != 'rgba(0,0,0,0)' and section.settings.background_color != blank -%}
      --section-background-color: {{ section.settings.background_color }};
    {%- endif -%}
    {%- if section.settings.accent_color != 'rgba(0,0,0,0)' and section.settings.accent_color != blank -%}
      --section-accent-color: {{ section.settings.accent_color }};
    {%- endif -%}
    {%- if section.settings.hover_color != 'rgba(0,0,0,0)' and section.settings.hover_color != blank -%}
      --section-hover-color: {{ section.settings.hover_color }};
    {%- endif -%}

    {%- if section.settings.product_card_hover_color != 'rgba(0,0,0,0)' and section.settings.product_card_hover_color != blank -%}
      --product-card-hover-color: {{ section.settings.product_card_hover_color }};
    {%- endif -%}
    {%- if section.settings.product_card_badges_background_color != 'rgba(0,0,0,0)' and section.settings.product_card_badges_background_color != blank -%}
      --product-card-badges-background-color: {{ section.settings.product_card_badges_background_color }};
    {%- endif -%}
    {%- if section.settings.product_card_badges_text_color != 'rgba(0,0,0,0)' and section.settings.product_card_badges_text_color != blank -%}
      --product-card-badges-text-color: {{ section.settings.product_card_badges_text_color }};
    {%- endif -%}
    {% if template.name == 'collection' and template.suffix == 'alle-produkte' %}
      --color-text: #2d2d2d;
      --color-text-title: #2d2d2d;
    {% endif %}
    {% if template.name == 'collection' and template.suffix == nil %}
      {%- assign nav_collection_ids = '283713765570,564020248840,519402258696,537731006728,519351828744' -%}
      {% if nav_collection_ids contains collection.id %}
        --color-text: #2d2d2d;
        --color-text-title: #2d2d2d;
      {% endif %}
    {% endif %}
  }
  
  /* Abstand zwischen Zacken-Divider und "Sortieren nach" - NUR Desktop */
  @media screen and (min-width: 992px) {
    #shopify-section-{{ section.id }} .products_listing.collection-template {
      padding-top: 80px !important;
    }
  }
  
  /* Abstand zwischen Zacken-Divider und "Sortieren nach" - NUR Mobile */
  @media screen and (max-width: 991px) {
    #shopify-section-{{ section.id }} .products_listing.collection-template {
      padding-top: 40px !important;
    }
  }
</style>
{% if template.name == 'collection' and template.suffix == 'alle-produkte' %}
<style>
  #shopify-section-{{ section.id }} .product-card__title,
  #shopify-section-{{ section.id }} .grid-view-item__title {
    color: #2d2d2d !important;
  }
  /* Header in Nude färben */
  .header {
    background-color: #F5F0EB !important;
  }
  /* Header Navigation und Icons schwarz */
  .header-nav__link,
  .header-nav__link svg,
  .header-nav__link svg path,
  .header-nav__link a {
    color: #000000 !important;
    fill: #000000 !important;
  }
  /* Hamburger Menü Striche schwarz */
  .hamburger-inner,
  .hamburger-inner::before,
  .hamburger-inner::after {
    background-color: #000000 !important;
  }
  /* Spezifisch für Lupe/Suche Icon */
  .header-nav__link--static svg,
  .header-nav__link--static svg path,
  [data-toggle="predictive-search-container"] svg,
  [data-toggle="predictive-search-container"] svg path {
    fill: #000000 !important;
    color: #000000 !important;
  }
    /* Zacken-Divider weiß für Übergang zum Footer */
    #shopify-section-{{ section.id }} .base-triangular-line,
    #shopify-section-{{ section.id }} .base-triangular-line svg,
    #shopify-section-{{ section.id }} .base-triangular-line svg path {
      color: #FFFFFF !important;
      fill: #FFFFFF !important;
    }
    /* Mobile: Schwarzer Rand um Labels bei Touch/Hover (damit sie auf nude Hintergrund sichtbar bleiben) */
    @media screen and (max-width: 768px) {
      .products_listing ul.grid li.grid__item:hover .products_listing__label,
      .products_listing ul.grid li.grid__item:active .products_listing__label,
      .products_listing ul.grid li.grid__item:focus-within .products_listing__label {
        border: 1px solid #000000 !important;
      }
    }
  </style>
{% endif %}

{% if template.name == 'collection' and template.suffix == nil %}
  {%- assign nav_collection_ids = '283713765570,564020248840,519402258696,537731006728,519351828744' -%}
  {% if nav_collection_ids contains collection.id %}
  <style>
    /* Header in Nude färben */
    .header {
      background-color: #F5F0EB !important;
    }
    /* Header Navigation und Icons schwarz */
    .header-nav__link,
    .header-nav__link svg,
    .header-nav__link svg path,
    .header-nav__link a {
      color: #000000 !important;
      fill: #000000 !important;
    }
    /* Hamburger Menü Striche schwarz */
    .hamburger-inner,
    .hamburger-inner::before,
    .hamburger-inner::after {
      background-color: #000000 !important;
    }
    /* Spezifisch für Lupe/Suche Icon */
    .header-nav__link--static svg,
    .header-nav__link--static svg path,
    [data-toggle="predictive-search-container"] svg,
    [data-toggle="predictive-search-container"] svg path {
      fill: #000000 !important;
      color: #000000 !important;
    }
    /* Zacken-Divider weiß für Übergang zum Footer */
    #shopify-section-{{ section.id }} .base-triangular-line,
    #shopify-section-{{ section.id }} .base-triangular-line svg,
    #shopify-section-{{ section.id }} .base-triangular-line svg path {
      color: #FFFFFF !important;
      fill: #FFFFFF !important;
    }
  </style>
  {% endif %}
{% endif %}

{% comment %} TODO: Cleanup this section {% endcomment %}
{%- assign collection_sort_by = collection.sort_by | default: collection.default_sort_by -%}
<div class="products_listing collection-template triangular-balance" data-section-id="{{ section.id }}">
  <div class="page-width" >
    <div class="product-facet__meta-bar-item product-facet__meta-bar-item--sort">
      <span class="product-facet__sort-by-title text--subdued hidden-pocket">{{ 'collections.sorting.title' | t }}</span>

      <popover-container class="popover-container">
        {%- for option in collection.sort_options -%}
          {%- if option.value == collection_sort_by -%}
            {%- assign collection_sort_by_name = option.name -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        <button type="button" class="popover-button hidden-pocket" aria-expanded="false">
          <span id="sort-by-selected-value" style="pointer-events: none">{{- collection_sort_by_name -}}</span>
          {%- render 'icon-chevron-down' -%}
        </button>

        <div class="popover">
          <span class="popover__overlay"></span>

          <header class="popover__header">
            <span class="popover__title heading h6">{{- 'collections.sorting.title' | t -}}</span>

            <button type="button" class="popover__close-button tap-area tap-area--large" title="{{ 'general.accessibility.close' | t | escape }}">
              {%- render 'icon-close' -%}
            </button>
          </header>

          <div class="popover__content">
            <div class="popover__choice-list">
              {%- for sort_option in collection.sort_options -%}
                <label class="popover__choice-item">
                  <input type="radio" data-bind-value="sort-by-selected-value" class="visually-hidden" {% if sort_option.value == collection_sort_by %}checked="checked"{% endif %} name="sort_by" value="{{ sort_option.value }}" title="{{ sort_option.name }}">
                  <span class="popover__choice-label">{{ sort_option.name }}</span>
                </label>
              {%- endfor -%}
            </div>
          </div>
        </div>
      </popover-container>
    </div>
    {% if section.settings.title != blank %}
      <div class="section-header text-center">
        <h2><span>{{ section.settings.title | escape }}</span></h2>
      </div>
    {% endif %}

    {% case section.settings.grid %}
      {% when 2 %}
        {%- assign max_height = 530 -%}
      {% when 3 %}
        {%- assign max_height = 345 -%}
      {% when 4 %}
        {%- assign max_height = 250 -%}
      {% when 5 %}
        {%- assign max_height = 195 -%}
    {% endcase %}

    {%- assign product_limit = section.settings.items_per_page -%}

    <ul class="grid grid--uniform grid--view-items">
      {% for product in collection.products limit: product_limit %}
        {%- if product.metafields.custom.hide_product -%}
          {%- continue -%}
        {%- endif -%}
        
        <li class="AAA grid__item grid__item--{{section.id}}">
          {% render 'product-card-grid', max_height: max_height, product: product, show_vendor: section.settings.show_vendor, index: forloop.index %}
        </li>
      {% endfor %}
    </ul>

    {% if section.settings.show_view_all %}
      <hr class="hr--invisible" aria-hidden="true" />
      <div class="text-center">
        <a href="{{ collection.url }}" class="btn" aria-label="{{ 'collections.general.view_all_label' | t: collection_name: collection.title }}">
          {{ 'collections.general.view_all' | t }}
        </a>
      </div>
    {% endif %}

  </div>
    <div class="base-triangular-line">
    {%- render 'icon-triangular-line' -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection page",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Featured collection"
    },
    {
      "type": "range",
      "id": "items_per_page",
      "label": "Items per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 48
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all",
      "default": false
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#2ac2bd"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#f3587f"
    },
    {
      "type": "color",
      "id": "hover_color",
      "label": "Hover Color",
      "default": "#dbaaeb"
    },
    {
      "type": "header",
      "content": "Product Card Colors"
    },
    {
      "type": "color",
      "id": "product_card_hover_color",
      "label": "Product Card Hover Color",
      "default": "#1d8884"
    },
    {
      "type": "color",
      "id": "product_card_badges_background_color",
      "label": "Product Card Badges Background Color",
      "default": "#6ad4d1"
    },
    {
      "type": "color",
      "id": "product_card_badges_text_color",
      "label": "Product Card Badges Text Color",
      "default": "#1d8884"
    }
  ],
  "presets": [
    {
      "name": "Collection page",
    }
  ]
}
{% endschema %}
